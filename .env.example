# Claude.ai Plan Usage Limits
# 取得方式：登入 claude.ai，DevTools → Network → usage 請求 → Copy as cURL

# URL 裡的 org UUID
CLAUDE_ORG_ID=your-org-uuid-here

# Cookie: sessionKey 的值（格式：sk-ant-sid01-...）
CLAUDE_SESSION_KEY=sk-ant-sid01-...

# Cookie: cf_clearance 的值（Cloudflare 防護 cookie）
CLAUDE_CF_CLEARANCE=your-cf_clearance-value

# Header: anthropic-device-id 的值
CLAUDE_DEVICE_ID=your-device-id-uuid

# Header: x-activity-session-id 的值（即 activitySessionId cookie）
CLAUDE_ACTIVITY_SESSION_ID=your-activity-session-id-uuid
